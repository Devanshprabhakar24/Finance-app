{
  "name": "finance-dashboard-monorepo",
  "version": "1.0.0",
  "description": "Finance Dashboard - Full Stack Application",
  "scripts": {
    "install:all": "npm install --prefix backend && npm install --prefix frontend",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build:backend": "npm run build --prefix backend",
    "build:frontend": "npm run build --prefix frontend",
    "build": "npm run build:backend && npm run build:frontend",
    "seed": "npm run seed --prefix backend",
    "test:backend": "npm test --prefix backend",
    "start:backend": "npm start --prefix backend",
    "start:frontend": "npm run preview --prefix frontend"
  },
  "keywords": ["finance", "dashboard", "fullstack"],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
