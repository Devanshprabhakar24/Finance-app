{
  "name": "finance-dashboard-backend",
  "version": "1.0.0",
  "description": "Production-grade Finance Dashboard Backend API with OTP authentication",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "node build.js",
    "tsc-build": "tsc --skipLibCheck --noEmitOnError false",
    "start": "node start-debug.js",
    "start:single": "node dist/server.js",
    "seed": "ts-node scripts/seed.ts",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "verify": "node verify-setup.js"
  },
  "keywords": [
    "finance",
    "dashboard",
    "api",
    "otp",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cloudinary": "^1.41.1",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "lru-cache": "^11.2.7",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.7",
    "prom-client": "^15.1.3",
    "rate-limit-redis": "^4.3.1",
    "swagger-ui-express": "^5.0.0",
    "twilio": "^4.20.0",
    "typescript": "^5.9.3",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/ioredis": "^4.28.10",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.16.0",
    "@typescript-eslint/parser": "^6.16.0",
    "cross-env": "^10.1.0",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0"
  }
}
