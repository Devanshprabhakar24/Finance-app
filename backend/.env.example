# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/finance-dashboard

# JWT
JWT_ACCESS_SECRET=your_access_secret_here_min_32_chars_random_string
JWT_REFRESH_SECRET=your_refresh_secret_here_min_32_chars_random_string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# OTP
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_TEST_MODE=false
OTP_TEST_CODE=123456

# Twilio (SMS)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# Email Service Configuration
# Set EMAIL_SERVICE to either "brevo" or "gmail"
EMAIL_SERVICE=gmail

# Brevo API Configuration (if using Brevo)
BREVO_API_KEY=your_brevo_api_key
BREVO_FROM_EMAIL=your-email@example.com

# Gmail SMTP Configuration (if using Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="Finance Dashboard <no-reply@finance.dev>"

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
