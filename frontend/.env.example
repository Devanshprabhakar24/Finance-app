# =============================================================================
# DEVELOPMENT ENVIRONMENT CONFIGURATION
# =============================================================================
# This is a template file showing all available environment variables.
# Copy this file to .env and customize the values for your local development.
#
# IMPORTANT: Never commit .env files with real credentials to version control.
# =============================================================================

# =============================================================================
# API CONFIGURATION
# =============================================================================
# VITE_API_BASE_URL: Backend API base URL
# Development: http://localhost:8000/api
# Production: https://your-backend-domain.com/api
VITE_API_BASE_URL=http://localhost:8000/api

# =============================================================================
# APPLICATION BRANDING
# =============================================================================
# VITE_APP_NAME: Main application name displayed in UI
# Used by: Page titles, headers, navigation, branding elements
VITE_APP_NAME=Finance Dashboard

# VITE_APP_DESCRIPTION: Application description for meta tags and about sections
# Used by: HTML meta description, landing page, about sections
VITE_APP_DESCRIPTION=Secure, Compliant & Intelligent Financial Systems

# VITE_APP_TAGLINE: Marketing tagline displayed on landing page
# Used by: Landing page hero section, marketing materials
VITE_APP_TAGLINE=Enterprise-Grade Financial Platform

# =============================================================================
# COMPANY INFORMATION
# =============================================================================
# VITE_COMPANY_NAME: Company name for legal/contact information
# Used by: Footer, contact forms, legal pages, support references
VITE_COMPANY_NAME=Finance Dashboard

# VITE_SUPPORT_EMAIL: Customer support email address
# Used by: Contact forms, error messages, help sections
VITE_SUPPORT_EMAIL=support@finance-dashboard.dev

# VITE_COMPANY_WEBSITE: Company website URL
# Used by: Footer links, about sections, external references
VITE_COMPANY_WEBSITE=https://finance-dashboard.dev

# =============================================================================
# APPLICATION URLS
# =============================================================================
# VITE_FRONTEND_URL: Frontend application URL
# Used by: CORS configuration, email templates, redirects
VITE_FRONTEND_URL=http://localhost:3000

# VITE_DOCS_URL: API documentation URL (Swagger/OpenAPI)
# Used by: Help sections, developer resources, API reference links
VITE_DOCS_URL=http://localhost:8000/api/docs

# VITE_REPOSITORY_URL: Source code repository URL
# Used by: About page, developer information, contribution links
VITE_REPOSITORY_URL=https://github.com/Devanshprabhakar24/Finance-app

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# VITE_REGISTRATION_ENABLED: Enable/disable user registration
# Used by: Registration forms, navigation, authentication flow
# Set to 'false' to disable new user signups
VITE_REGISTRATION_ENABLED=true

# VITE_DEMO_MODE: Enable demo mode with test credentials
# Used by: Login page, displays demo credentials for easy testing
# Set to 'true' in development, 'false' in production
VITE_DEMO_MODE=true

# VITE_ANALYTICS_ENABLED: Enable analytics tracking
# Used by: Analytics components, tracking scripts
# Set to 'false' to disable all analytics
VITE_ANALYTICS_ENABLED=false

# VITE_FILE_UPLOAD_ENABLED: Enable file upload functionality
# Used by: File upload components, attachment features
# Set to 'false' to disable file uploads
VITE_FILE_UPLOAD_ENABLED=true

# =============================================================================
# THEME CONFIGURATION
# =============================================================================
# VITE_PRIMARY_COLOR: Primary brand color (CSS hex value)
# Used by: Buttons, links, primary UI elements
# Default: #6366f1 (Indigo)
VITE_PRIMARY_COLOR=#6366f1

# VITE_SECONDARY_COLOR: Secondary brand color (CSS hex value)
# Used by: Accent elements, secondary buttons, highlights
# Default: #8b5cf6 (Purple)
VITE_SECONDARY_COLOR=#8b5cf6

# VITE_LOGO_URL: Custom logo URL (optional)
# Used by: Navigation header, branding elements
# Leave empty to use default text-based logo
VITE_LOGO_URL=

# =============================================================================
# DEMO CREDENTIALS
# =============================================================================
# These credentials are displayed in the UI when VITE_DEMO_MODE=true
# They allow users to quickly test the application with different roles
# SECURITY NOTE: These are public test accounts, not real user credentials

# VITE_DEMO_ADMIN_EMAIL: Demo admin account email
# Role: Full administrative access
VITE_DEMO_ADMIN_EMAIL=admin@finance.com

# VITE_DEMO_ADMIN_PASSWORD: Demo admin account password
VITE_DEMO_ADMIN_PASSWORD=admin123

# VITE_DEMO_ANALYST_EMAIL: Demo analyst account email
# Role: Data analysis and reporting access
VITE_DEMO_ANALYST_EMAIL=analyst@finance.dev

# VITE_DEMO_ANALYST_PASSWORD: Demo analyst account password
VITE_DEMO_ANALYST_PASSWORD=Demo@12345

# VITE_DEMO_VIEWER_EMAIL: Demo viewer account email
# Role: Read-only access to financial data
VITE_DEMO_VIEWER_EMAIL=viewer@finance.dev

# VITE_DEMO_VIEWER_PASSWORD: Demo viewer account password
VITE_DEMO_VIEWER_PASSWORD=Demo@12345

# =============================================================================
# THIRD-PARTY SERVICES
# =============================================================================
# VITE_CLOUDINARY_CLOUD_NAME: Cloudinary cloud name for file uploads
# Used by: File upload components, image processing, avatar uploads
# Required for: Profile pictures, document attachments, image optimization
# Get this from your Cloudinary dashboard: https://cloudinary.com/console
VITE_CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
