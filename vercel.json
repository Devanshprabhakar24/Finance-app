{
  "version": 2,
  "builds": [
    {
      "src": "Finance-app-improved/frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "Finance-app-improved/frontend/dist",
        "installCommand": "cd Finance-app-improved/frontend && npm install --legacy-peer-deps"
      }
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/Finance-app-improved/frontend/dist/index.html"
    }
  ]
}